default_platform(:android)

platform :android do
  desc "Build debug APKs and capture localized Play Store screenshots"
  lane :screenshots do
    gradle(task: "clean")
    gradle(task: "assembleDebug")
    gradle(task: "assembleDebugAndroidTest")

    capture_android_screenshots
  end

  desc "Capture localized Play Store screenshots using already built debug APKs"
  lane :screenshots_capture_only do
    capture_android_screenshots
  end
end
